      <property name="styleSheet">
       <string notr="true">QPushButton {
    background-color: rgb(0, 121, 184);  /* 按钮默认背景色 */
    color: white;                        /* 文字白色 */
    border: none;                        /* 去掉默认边框 */
    font-size: 25px;                     /* 文字大小 */
    border-radius: 15px;                 /* 圆角大小（数字越大越圆） */
    padding: 10px 20px;                  /* 按钮内边距，让按钮更饱满 */
}

QPushButton:hover {
    background-color: rgb(30, 0, 120);   /* 鼠标放上去的颜色 */
    border-radius: 15px;                 /* 圆角保持一致 */
}

QPushButton:pressed {
    background-color: rgb(42, 91, 154);  /* 鼠标按下的颜色 */
    border-radius: 15px;                 /* 圆角保持一致 */
}</string>
